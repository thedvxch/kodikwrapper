{
  "name": "kodikwrapper",
  "version": "3.0.6",
  "description": "A kodikapi.com wrapper for Node.JS",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "rm -rf ./dist && tsup",
    "test": "vitest",
    "lint": "biome check",
    "format": "biome format --write",
    "docs": "typedoc --out docs src/index.ts --gitRevision master --skipErrorChecking"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^20.19.43",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.20",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "kodik"
  ],
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/thedvxch/kodikwrapper",
  "repository": {
    "type": "git",
    "url": "https://github.com/thedvxch/kodikwrapper.git"
  },
  "author": "thedvxch",
  "license": "WTFPL"
}
